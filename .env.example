APP_ENV=development

P1_DATA_ROOT=./var/data
P1_LOGS_ROOT=./var/logs
P1_CERTIFICATES_BASE_PATH=./var/certs

# Optional per-path overrides:
# P1_INBOX_PATH=/sciezka/do/inbox
# P1_PROCESSING_PATH=/sciezka/do/processing
# P1_DONE_PATH=/sciezka/do/done
# P1_INVALID_PATH=/sciezka/do/invalid
# P1_RESULTS_PATH=/sciezka/do/results
# P1_AUDIT_LOG_PATH=/sciezka/do/logs/audit.jsonl

REDIS_URL=redis://127.0.0.1:6379/0
SIGNATURE_SERVICE_URL=http://127.0.0.1:9093
SIGNATURE_TOOL_SIGNING_CERTIFICATE_PATH=/certs/wss.p12
SIGNATURE_TOOL_SIGNING_PASSWORD=

HOST_REDIS_PORT=6379

P1_ENVIRONMENT=integration

WSS_CERT_PASSWORD=
TLS_CERT_PASSWORD=
